# ─── Database ──────────────────────────────────────────────
DATABASE_URL="postgresql://dbm:dbm_secret@localhost:5432/dbm_portal?schema=public"

# ─── Firebase Auth ─────────────────────────────────────────
FIREBASE_PROJECT_ID="your-firebase-project-id"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk@your-project.iam.gserviceaccount.com"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY\n-----END PRIVATE KEY-----"

# ─── AWS S3 (LocalStack for dev) ──────────────────────────
AWS_ACCESS_KEY_ID="test"
AWS_SECRET_ACCESS_KEY="test"
AWS_REGION="us-east-1"
AWS_S3_BUCKET="dbm-uploads"
AWS_S3_ENDPOINT="http://localhost:4566"

# ─── Anthropic (AI Scope Architect) ───────────────────────
ANTHROPIC_API_KEY="sk-ant-your-key-here"

# ─── App ───────────────────────────────────────────────────
API_PORT=4000
WEB_URL="http://localhost:3000"
API_URL="http://localhost:4000"
NODE_ENV="development"
SESSION_SECRET="change-me-in-production-use-a-random-64-char-string"
