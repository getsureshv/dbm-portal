// ─── DBM Construction Portal — Prisma Schema ──────────────
// Phase 1: Foundation + AI Scope Architect
// Database: PostgreSQL 16

generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ─────────────────────────────────────────────────

enum UserRole {
  OWNER
  PROVIDER
  ADMIN
}

enum ProviderType {
  PROFESSIONAL
  SUPPLIER
  FREIGHT
}

enum LicenseStatus {
  ACTIVE
  EXPIRED
  NONE
  NOT_APPLICABLE
}

enum ProjectType {
  RESIDENTIAL
  COMMERCIAL
  NEW_BUILD
}

enum ProjectStatus {
  DISCOVERY
  BIDDING
  CONTRACTING
  EXECUTION
  CLOSING
  ARCHIVED
}

enum ScopeStatus {
  DRAFT
  IN_PROGRESS
  COMPLETE
  FINALIZED
}

enum ScopeCreationMode {
  AI_ASSISTED
  MANUAL_UPLOAD
}

enum DocumentCategory {
  LEGAL
  FINANCIAL
  TECHNICAL
  COMPLIANCE
}

enum TradeGroup {
  PLANNING_DESIGN
  CONTRACTORS
  SUPPLIERS
  SERVICES
}

// Phase 5 stub enums
enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

enum ChangeOrderStatus {
  PENDING
  IN_REVIEW
  APPROVED
  REJECTED
}

enum RfiStatus {
  OPEN
  RESPONDED
  CLOSED
}

enum SubmittalStatus {
  PENDING
  APPROVED
  REJECTED
  RESUBMIT
}

enum DeliveryStatus {
  SCHEDULED
  IN_TRANSIT
  DELIVERED
  DELAYED
}

enum ReportStatus {
  DRAFT
  SUBMITTED
  REVIEWED
}

// ─── CORE MODELS ───────────────────────────────────────────

model User {
  id                 String        @id @default(uuid()) @db.Uuid
  email              String        @unique
  firebaseUid        String        @unique @map("firebase_uid")
  role               UserRole?
  providerType       ProviderType? @map("provider_type")
  name               String?
  phone              String?
  languagePreference String        @default("en") @map("language_preference")
  verificationStatus Boolean       @default(true) @map("verification_status")
  onboardingComplete Boolean       @default(false) @map("onboarding_complete")
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")

  // Relations
  professionalProfile ProfessionalProfile?
  supplierProfile     SupplierProfile?
  freightProfile      FreightProfile?
  projects            Project[]
  uploadedDocuments   ProjectDocument[]
  chatConversations   ChatConversation[]
  UserPersona         UserPersona[]

  @@map("users")
}

// ─── PROVIDER PROFILES ─────────────────────────────────────

model ProfessionalProfile {
  id                String        @id @default(uuid()) @db.Uuid
  userId            String        @unique @map("user_id") @db.Uuid
  firstName         String        @map("first_name")
  middleName        String?       @map("middle_name")
  lastName          String        @map("last_name")
  companyName       String        @map("company_name")
  contactNumber1    String        @map("contact_number_1")
  contactNumber2    String?       @map("contact_number_2")
  email             String
  website           String?
  address           Json? // Structured: { street, streetNumber, suite, city, state, country, zipCode }
  yearsInProfession Int?          @map("years_in_profession")
  yearsInBusiness   Int?          @map("years_in_business")
  licenseNumber     String?       @map("license_number")
  licenseStatus     LicenseStatus @default(NOT_APPLICABLE) @map("license_status")
  styleOfWork       String[]      @map("style_of_work")
  awards            String[]      @default([])
  portfolioKey      String?       @map("portfolio_key") // S3 key
  profileImageKey   String?       @map("profile_image_key")
  insuranceCertKey  String?       @map("insurance_cert_key")

  // Trade taxonomy
  tradeCategoryId String? @map("trade_category_id") @db.Uuid
  tradeNameId     String? @map("trade_name_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  tradeCategory TradeCategory? @relation(fields: [tradeCategoryId], references: [id])
  tradeName     TradeName?     @relation(fields: [tradeNameId], references: [id])

  @@index([tradeCategoryId])
  @@index([tradeNameId])
  @@index([licenseStatus])
  @@map("professional_profiles")
}

model SupplierProfile {
  id                 String        @id @default(uuid()) @db.Uuid
  userId             String        @unique @map("user_id") @db.Uuid
  firstName          String        @map("first_name")
  middleName         String?       @map("middle_name")
  lastName           String        @map("last_name")
  companyName        String        @map("company_name")
  contactNumber1     String        @map("contact_number_1")
  contactNumber2     String?       @map("contact_number_2")
  email              String
  website            String?
  address            Json?
  materialTypes      String[]      @map("material_types")
  servicesProvided   String[]      @map("services_provided")
  multipleLocations  Boolean       @default(false) @map("multiple_locations")
  secondaryAddresses Json?         @map("secondary_addresses") // Array of Address objects
  licenseStatus      LicenseStatus @default(NOT_APPLICABLE) @map("license_status")
  profileImageKey    String?       @map("profile_image_key")
  portfolioKey       String?       @map("portfolio_key")

  tradeCategoryId String? @map("trade_category_id") @db.Uuid
  tradeNameId     String? @map("trade_name_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  tradeCategory TradeCategory? @relation(fields: [tradeCategoryId], references: [id])
  tradeName     TradeName?     @relation(fields: [tradeNameId], references: [id])

  @@map("supplier_profiles")
}

model FreightProfile {
  id                 String        @id @default(uuid()) @db.Uuid
  userId             String        @unique @map("user_id") @db.Uuid
  firstName          String        @map("first_name")
  middleName         String?       @map("middle_name")
  lastName           String        @map("last_name")
  companyName        String        @map("company_name")
  contactNumber1     String        @map("contact_number_1")
  contactNumber2     String?       @map("contact_number_2")
  email              String
  website            String?
  address            Json?
  serviceTypes       String[]      @map("service_types")
  servicesProvided   String[]      @map("services_provided")
  multipleLocations  Boolean       @default(false) @map("multiple_locations")
  secondaryAddresses Json?         @map("secondary_addresses")
  licenseStatus      LicenseStatus @default(NOT_APPLICABLE) @map("license_status")
  profileImageKey    String?       @map("profile_image_key")
  portfolioKey       String?       @map("portfolio_key")

  tradeCategoryId String? @map("trade_category_id") @db.Uuid
  tradeNameId     String? @map("trade_name_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  tradeCategory TradeCategory? @relation(fields: [tradeCategoryId], references: [id])
  tradeName     TradeName?     @relation(fields: [tradeNameId], references: [id])

  @@map("freight_profiles")
}

// ─── TRADE TAXONOMY ────────────────────────────────────────

model TradeCategory {
  id    String     @id @default(uuid()) @db.Uuid
  name  TradeGroup @unique
  label String // Human-readable: "Planning & Design"

  trades               TradeName[]
  professionalProfiles ProfessionalProfile[]
  supplierProfiles     SupplierProfile[]
  freightProfiles      FreightProfile[]

  @@map("trade_categories")
}

model TradeName {
  id         String @id @default(uuid()) @db.Uuid
  categoryId String @map("category_id") @db.Uuid
  name       String // "General Contractor"
  slug       String @unique // "general-contractor"

  category             TradeCategory         @relation(fields: [categoryId], references: [id])
  professionalProfiles ProfessionalProfile[]
  supplierProfiles     SupplierProfile[]
  freightProfiles      FreightProfile[]

  @@index([categoryId])
  @@map("trade_names")
}

// ─── PROJECTS ──────────────────────────────────────────────

model Project {
  id                String            @id @default(uuid()) @db.Uuid
  ownerId           String            @map("owner_id") @db.Uuid
  title             String
  type              ProjectType       @default(RESIDENTIAL)
  status            ProjectStatus     @default(DISCOVERY)
  zipCode           String            @map("zip_code")
  description       String?
  scopeCreationMode ScopeCreationMode @default(AI_ASSISTED) @map("scope_creation_mode")
  deletedAt         DateTime?         @map("deleted_at")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  // Relations
  owner           User              @relation(fields: [ownerId], references: [id])
  documents       ProjectDocument[]
  scopeDocument   ScopeDocument?
  // Phase 5+ stubs
  invoices        Invoice[]
  changeOrders    ChangeOrder[]
  rfis            Rfi[]
  submittals      Submittal[]
  deliveryReports DeliveryReport[]
  progressReports ProgressReport[]

  @@index([ownerId])
  @@index([zipCode])
  @@index([status])
  @@map("projects")
}

model ProjectDocument {
  id            String           @id @default(uuid()) @db.Uuid
  projectId     String           @map("project_id") @db.Uuid
  category      DocumentCategory @default(TECHNICAL)
  filename      String
  s3Key         String           @map("s3_key")
  extractedText String?          @map("extracted_text")
  uploadedById  String           @map("uploaded_by_id") @db.Uuid
  createdAt     DateTime         @default(now()) @map("created_at")

  project    Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploadedBy User    @relation(fields: [uploadedById], references: [id])

  @@index([projectId])
  @@map("project_documents")
}

// ─── AI SCOPE ARCHITECT ────────────────────────────────────

model ScopeDocument {
  id                  String      @id @default(uuid()) @db.Uuid
  projectId           String      @unique @map("project_id") @db.Uuid
  status              ScopeStatus @default(DRAFT)
  completenessPercent Int         @default(0) @map("completeness_percent")
  pdfS3Key            String?     @map("pdf_s3_key")
  createdAt           DateTime    @default(now()) @map("created_at")
  updatedAt           DateTime    @updatedAt @map("updated_at")

  // Structured scope data — populated field-by-field by the AI
  projectScope         String? @map("project_scope")
  dimensions           String?
  materialGrade        String? @map("material_grade")
  timeline             String?
  milestones           String?
  specialConditions    String? @map("special_conditions")
  preferredStartDate   String? @map("preferred_start_date")
  siteConstraints      String? @map("site_constraints")
  aestheticPreferences String? @map("aesthetic_preferences")

  project        Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  interviewTurns ScopeInterviewTurn[]

  @@map("scope_documents")
}

model ScopeInterviewTurn {
  id              String   @id @default(uuid()) @db.Uuid
  scopeDocumentId String   @map("scope_document_id") @db.Uuid
  turnNumber      Int      @map("turn_number")
  questionText    String   @map("question_text")
  answerText      String?  @map("answer_text")
  fieldPopulated  String?  @map("field_populated") // Which ScopeDocument field was updated
  createdAt       DateTime @default(now()) @map("created_at")

  scopeDocument ScopeDocument @relation(fields: [scopeDocumentId], references: [id], onDelete: Cascade)

  @@index([scopeDocumentId])
  @@map("scope_interview_turns")
}

// ─── AI CHAT (General Assistant) ───────────────────────────

model ChatConversation {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  title     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages ChatMessage[]

  @@index([userId])
  @@map("chat_conversations")
}

model ChatMessage {
  id             String   @id @default(uuid()) @db.Uuid
  conversationId String   @map("conversation_id") @db.Uuid
  role           String // USER | ASSISTANT | TOOL
  content        Json // Supports Anthropic content blocks
  tokensIn       Int?     @map("tokens_in")
  tokensOut      Int?     @map("tokens_out")
  createdAt      DateTime @default(now()) @map("created_at")

  conversation ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("chat_messages")
}

// ─── FEATURE FLAGS (A/B Testing) ───────────────────────────

model FeatureFlag {
  id        String   @id @default(uuid()) @db.Uuid
  key       String   @unique // e.g. "scope_creation_mode"
  variant   String // e.g. "ai_assisted" | "manual_upload"
  userId    String?  @map("user_id") @db.Uuid // null = global default
  createdAt DateTime @default(now()) @map("created_at")

  @@index([key, userId])
  @@map("feature_flags")
}

// ─── PHASE 5+ STUB MODELS (schema-ready, not built yet) ───

model Invoice {
  id        String        @id @default(uuid()) @db.Uuid
  projectId String        @map("project_id") @db.Uuid
  status    InvoiceStatus @default(DRAFT)
  amount    Decimal?      @db.Decimal(12, 2)
  dueDate   DateTime?     @map("due_date")
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")
  project   Project       @relation(fields: [projectId], references: [id])

  @@map("invoices")
}

model ChangeOrder {
  id           String            @id @default(uuid()) @db.Uuid
  projectId    String            @map("project_id") @db.Uuid
  status       ChangeOrderStatus @default(PENDING)
  description  String?
  impactAmount Decimal?          @map("impact_amount") @db.Decimal(12, 2)
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")
  project      Project           @relation(fields: [projectId], references: [id])

  @@map("change_orders")
}

model Rfi {
  id        String    @id @default(uuid()) @db.Uuid
  projectId String    @map("project_id") @db.Uuid
  status    RfiStatus @default(OPEN)
  question  String?
  response  String?
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  project   Project   @relation(fields: [projectId], references: [id])

  @@map("rfis")
}

model Submittal {
  id        String          @id @default(uuid()) @db.Uuid
  projectId String          @map("project_id") @db.Uuid
  status    SubmittalStatus @default(PENDING)
  title     String?
  s3Key     String?         @map("s3_key")
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")
  project   Project         @relation(fields: [projectId], references: [id])

  @@map("submittals")
}

model DeliveryReport {
  id        String         @id @default(uuid()) @db.Uuid
  projectId String         @map("project_id") @db.Uuid
  status    DeliveryStatus @default(SCHEDULED)
  vendor    String?
  items     Json?
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")
  project   Project        @relation(fields: [projectId], references: [id])

  @@map("delivery_reports")
}

model ProgressReport {
  id          String       @id @default(uuid()) @db.Uuid
  projectId   String       @map("project_id") @db.Uuid
  status      ReportStatus @default(DRAFT)
  summary     String?
  percentDone Int?         @map("percent_done")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  project     Project      @relation(fields: [projectId], references: [id])

  @@map("progress_reports")
}

// ─── CITY INTEGRATION (Demo: Dallas + Flower Mound) ─────────
// One Jurisdiction per city; one Adapter per Jurisdiction.vendor.
// Permits and CodeRules normalize across all city vendors.

enum JurisdictionVendor {
  ACCELA // Accela Construct API (per-agency partnership)
  DALLAS_OPENDATA // Dallas Socrata OpenData portal (public, no-auth) — preset of SOCRATA
  SOCRATA // generic, config-driven Socrata adapter (any Socrata city via fieldMap)
  SHOVELS // aggregator fallback
  ETRAKIT // CentralSquare eTRAKiT (Flower Mound)
  ILMS // Houston legacy (deferred)
  MOCK // demo / dev fallback
}

enum PermitStatus {
  OPEN
  ISSUED
  FINALIZED
  EXPIRED
  CANCELLED
  UNKNOWN
}

enum CodeFamily {
  IBC // International Building Code
  IRC // International Residential Code
  IECC // Energy
  IPC // Plumbing
  IMC // Mechanical
  NEC // Electrical (NFPA 70)
  LOCAL // City amendment
}

model Jurisdiction {
  id                String             @id @default(uuid()) @db.Uuid
  name              String // e.g. "City of Dallas"
  state             String             @db.VarChar(2) // "TX" (kept for backwards compat; Phase 3 aliases to regionCode)
  slug              String             @unique // "dallas-tx"
  fips              String? // county/place FIPS (US-only; Phase 3 generalizes to geoIds Json)
  vendor            JurisdictionVendor
  hasZoning         Boolean            @default(true) @map("has_zoning")
  adapterConfig     Json?              @map("adapter_config") // tokens scoped to env, NOT secrets
  zipPrefixes       String[]           @map("zip_prefixes") // simple address→jurisdiction resolver
  // ─── i18n / global-ready fields (Phase 2.5) ───
  countryCode       String             @default("US") @map("country_code") @db.Char(2) // ISO 3166-1 alpha-2
  timezone          String             @default("America/Chicago") // IANA tz database
  measurementSystem MeasurementSystem  @default(IMPERIAL) @map("measurement_system")
  defaultCurrency   String             @default("USD") @map("default_currency") @db.Char(3) // ISO 4217
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  permits           Permit[]
  codeRules         CodeRule[]
  addressLookups    AddressLookup[]
  codeRuleLookups   CodeRuleLookup[]

  @@index([countryCode, state])
  @@map("jurisdictions")
}

enum MeasurementSystem {
  IMPERIAL // ft, in, sq ft, lb, °F  — US, Liberia, Myanmar
  METRIC // m, mm, m², kg, °C       — rest of world
}

model Permit {
  id                String       @id @default(uuid()) @db.Uuid
  jurisdictionId    String       @map("jurisdiction_id") @db.Uuid
  externalId        String       @map("external_id") // city's permit number
  address           String // normalized
  type              String? // "Residential Deck" etc.
  status            PermitStatus @default(UNKNOWN)
  issuedAt          DateTime?    @map("issued_at")
  finalizedAt       DateTime?    @map("finalized_at")
  contractor        String? // pro/contractor of record
  valuation         Decimal?     @db.Decimal(14, 2)
  valuationCurrency String?      @map("valuation_currency") @db.Char(3) // ISO 4217; nullable for legacy rows
  description       String?
  raw               Json? // raw vendor payload for audit
  fetchedAt         DateTime     @default(now()) @map("fetched_at")
  jurisdiction      Jurisdiction @relation(fields: [jurisdictionId], references: [id])

  @@unique([jurisdictionId, externalId])
  @@index([address])
  @@map("permits")
}

model CodeRule {
  id             String       @id @default(uuid()) @db.Uuid
  jurisdictionId String       @map("jurisdiction_id") @db.Uuid
  codeFamily     CodeFamily   @map("code_family")
  section        String // e.g. "R507"
  title          String
  body           String // Markdown / plain text
  scopeTags      String[]     @map("scope_tags") // ["deck","adu","kitchen"]
  effectiveDate  DateTime?    @map("effective_date")
  sourceUrl      String?      @map("source_url")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  jurisdiction   Jurisdiction @relation(fields: [jurisdictionId], references: [id])

  @@unique([jurisdictionId, codeFamily, section])
  @@index([jurisdictionId, scopeTags])
  @@map("code_rules")
}

model AddressLookup {
  id                String       @id @default(uuid()) @db.Uuid
  address           String // normalized input
  jurisdictionId    String       @map("jurisdiction_id") @db.Uuid
  lastSyncedAt      DateTime     @default(now()) @map("last_synced_at")
  ttlSeconds        Int          @default(86400) @map("ttl_seconds")
  // externalIds of the permits returned for THIS lookup. Cached reads use this
  // instead of matching Permit.address, because zip-scoped vendors (Shovels)
  // return the same permits for many addresses and a single Permit row can only
  // carry one address string — matching by address stranded the cache at 0.
  permitExternalIds String[]     @default([]) @map("permit_external_ids")
  jurisdiction      Jurisdiction @relation(fields: [jurisdictionId], references: [id])

  @@unique([address, jurisdictionId])
  @@map("address_lookups")
}

// Freshness marker for dynamically-extracted code rules. Mirrors AddressLookup:
// one row per (jurisdiction, scope). When a lookup is stale/absent we re-fetch
// the city's published code, extract rules with an LLM, upsert them as CodeRule
// rows, and stamp this marker. No code rules are pre-seeded for new cities.
model CodeRuleLookup {
  id             String       @id @default(uuid()) @db.Uuid
  jurisdictionId String       @map("jurisdiction_id") @db.Uuid
  scope          String       @default("") // "" = no-scope/general lookup
  lastSyncedAt   DateTime     @default(now()) @map("last_synced_at")
  ttlSeconds     Int          @default(604800) @map("ttl_seconds") // 7d — codes change slowly
  sourceUrl      String?      @map("source_url")
  ruleCount      Int          @default(0) @map("rule_count")
  jurisdiction   Jurisdiction @relation(fields: [jurisdictionId], references: [id])

  @@unique([jurisdictionId, scope])
  @@map("code_rule_lookups")
}

// ─── PERSONA & ACCESS MANAGEMENT ───────────────────────────
// Foundation authorization module. Replaces the single User.role enum with a
// many-personas-per-user model + entity/action/scope permissions + per-record
// grants + append-only audit. Spec: DBM-persona-access-module-spec.md §4.
// NOTE: legacy User.role / User.providerType columns are kept during the build
// (back-filled into UserPersona) and dropped in a later cleanup migration.

enum PersonaBaseType {
  CLIENT
  PROFESSIONAL
  SUPPLIER
  FREIGHT
  SERVICE_PROVIDER
  ADMIN
  CUSTOM
}

enum PersonaStatus {
  ACTIVE
  ARCHIVED
}

// scope:own / scope:assigned resolution lives on the Entity registry rows.
enum PermissionScope {
  ALL
  OWN
  ASSIGNED
}

enum UserPersonaStatus {
  PENDING
  ACTIVE
  REVOKED
  EXPIRED
}

enum GranteeType {
  USER
  PERSONA
}

enum RecordGrantStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

// Admin-managed role template. Holds embedded permissions (one row per entity
// via PersonaPermission). Seeded as data; editable by admin afterwards.
model Persona {
  id               String          @id @default(uuid()) @db.Uuid
  name             String
  slug             String          @unique
  description      String?
  baseType         PersonaBaseType @map("base_type")
  isSystem         Boolean         @default(false) @map("is_system")
  status           PersonaStatus   @default(ACTIVE)
  requiresApproval Boolean         @default(false) @map("requires_approval")
  createdBy        String?         @map("created_by") @db.Uuid
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")

  permissions  PersonaPermission[]
  userPersonas UserPersona[]

  @@index([status])
  @@map("personas")
}

// One row per (persona, entity): the actions allowed and the scope.
model PersonaPermission {
  id        String          @id @default(uuid()) @db.Uuid
  personaId String          @map("persona_id") @db.Uuid
  entityKey String          @map("entity_key")
  actions   String[] // e.g. ["read","update","create"]
  scope     PermissionScope @default(OWN)

  persona Persona @relation(fields: [personaId], references: [id], onDelete: Cascade)
  entity  Entity  @relation(fields: [entityKey], references: [key])

  @@unique([personaId, entityKey])
  @@index([entityKey])
  @@map("persona_permissions")
}

// Resource registry — drives the admin permission-matrix UI and scope
// resolution. Editable by admin without a code change.
model Entity {
  key                  String   @id // "project", "bid", "contract", ...
  label                String
  actions              String[] // supported actions for this entity
  supportsRecordGrants Boolean  @default(true) @map("supports_record_grants")
  ownerField           String?  @map("owner_field") // resolves scope:own (e.g. "clientId")
  participantSource    String?  @map("participant_source") // resolves scope:assigned
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  permissions PersonaPermission[]

  @@map("entities")
}

// A persona attached to a user account. One person, many personas.
model UserPersona {
  id         String            @id @default(uuid()) @db.Uuid
  userId     String            @map("user_id") @db.Uuid
  personaId  String            @map("persona_id") @db.Uuid
  assignedBy String?           @map("assigned_by") @db.Uuid
  assignedAt DateTime          @default(now()) @map("assigned_at")
  expiresAt  DateTime?         @map("expires_at")
  status     UserPersonaStatus @default(ACTIVE)

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  persona Persona @relation(fields: [personaId], references: [id])

  @@unique([userId, personaId])
  @@index([userId, status])
  @@map("user_personas")
}

// Per-record exception: grant actions on one record to a user or a persona.
model RecordGrant {
  id          String            @id @default(uuid()) @db.Uuid
  entity      String // entity key
  recordId    String            @map("record_id")
  granteeType GranteeType       @map("grantee_type")
  granteeId   String            @map("grantee_id") @db.Uuid
  actions     String[]
  reason      String // mandatory free-text
  grantedBy   String            @map("granted_by") @db.Uuid
  grantedAt   DateTime          @default(now()) @map("granted_at")
  expiresAt   DateTime?         @map("expires_at")
  status      RecordGrantStatus @default(ACTIVE)

  @@index([entity, recordId, status])
  @@index([granteeType, granteeId, status])
  @@map("record_grants")
}

// Append-only audit of every authorization change. Written transactionally.
model PermissionAuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  actorId     String?  @map("actor_id") @db.Uuid
  action      String // e.g. "persona.updated"
  subjectType String   @map("subject_type")
  subjectId   String?  @map("subject_id")
  before      Json?
  after       Json?
  at          DateTime @default(now())

  @@index([actorId])
  @@index([subjectType, subjectId])
  @@index([at])
  @@map("permission_audit_log")
}
