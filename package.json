{
  "name": "dbm-portal",
  "version": "0.1.0",
  "private": true,
  "description": "DBM Construction Services Portal — Phase 1",
  "scripts": {
    "dev": "pnpm --parallel --filter @dbm/web --filter @dbm/api run dev",
    "dev:web": "pnpm --filter @dbm/web dev",
    "dev:api": "pnpm --filter @dbm/api dev",
    "build": "pnpm --filter @dbm/web --filter @dbm/api run build",
    "lint": "pnpm --recursive run lint",
    "typecheck": "pnpm --recursive run typecheck",
    "test": "pnpm --recursive run test",
    "test:e2e": "pnpm --filter @dbm/web run test:e2e",
    "db:generate": "pnpm --filter @dbm/api prisma generate",
    "db:migrate": "pnpm --filter @dbm/api prisma migrate dev",
    "db:seed": "pnpm --filter @dbm/api prisma db seed",
    "db:studio": "pnpm --filter @dbm/api prisma studio",
    "docker:up": "docker compose -f infra/docker-compose.yml up -d",
    "docker:down": "docker compose -f infra/docker-compose.yml down",
    "setup": "pnpm install && pnpm docker:up && pnpm db:generate && pnpm db:migrate && pnpm db:seed"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
